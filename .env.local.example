# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Prisma / Database
# Get from Supabase > Project Settings > Database > Connection string (Transaction mode)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Get from Supabase > Project Settings > Database > Connection string (Session mode)
DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Redis (for BullMQ - Phase 7)
REDIS_URL=redis://localhost:6379

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
