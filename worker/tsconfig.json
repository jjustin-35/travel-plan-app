{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "./dist",
    "rootDir": "../",
    "paths": {
      "@/*": ["../src/*"]
    }
  },
  "include": ["index.ts", "../src/lib/db/prisma.ts", "../src/generated/prisma/**/*.ts", "../src/lib/schemas/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
